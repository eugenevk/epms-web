rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwnUserSettingsDoc() {
      return isSignedIn()
        && request.auth.token.email != null
        && resource.data.username == request.auth.token.email;
    }

    function isOwnUserSettingsUpdate() {
      return isOwnUserSettingsDoc()
        && request.resource.data.username == resource.data.username
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'avatarUrl', 'avatarPath', 'updatedAt', 'updatedBy']);
    }

    match /system/{systemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /userSettings/{settingsId} {
      allow read: if isAdmin() || isOwnUserSettingsDoc();
      allow update: if isAdmin() || isOwnUserSettingsUpdate();
      allow create, delete: if isAdmin();
    }

    match /{collection}/{document=**} {
      allow read, write: if isSignedIn() && collection != 'system' && collection != 'userSettings';
    }
  }
}
