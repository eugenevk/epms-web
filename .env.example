# Index sync: Firebase Extension "Search Firestore with Algolia" (one instance per collection)
# → see docs/ALGOLIA_SYNC.md (install extensions for products + productsInUse)

# REST Countries (https://restcountries.com)
VITE_RESTCOUNTRIES_API_KEY=
