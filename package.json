{
  "name": "epms-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Eus Presales Management System — nieuwe frontend",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "copy:hosting": "node scripts/copy-to-epms-hosting.mjs",
    "build:hosting": "npm run build && npm run copy:hosting",
    "release:hosting": "npm run build && node scripts/release-hosting.mjs"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/vue-fontawesome": "^3.3.0",
    "@tinymce/tinymce-vue": "^6.3.0",
    "algoliasearch": "^4.27.0",
    "firebase": "^11.6.0",
    "pinia": "^2.3.1",
    "tinymce": "^8.6.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^5.4.14",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": ">=18"
  }
